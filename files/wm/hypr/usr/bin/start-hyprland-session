#!/bin/bash
# Startup script for Hyprland session using static systemd services
# To be called from .bash_profile when logging in on tty1

set -euo pipefail

# Check if we're on tty1
if [[ "$(tty)" != "/dev/tty1" ]]; then
    echo "Hyprland session should only be started from tty1"
    exit 1
fi

# Check if a graphical session is already running
if systemctl --user is-active --quiet graphical-session.target; then
    echo "A graphical session is already running"
    exit 1
fi

echo "Starting Hyprland session..."

# Import current environment into systemd user manager
# This ensures variables from login shell are available to services
systemctl --user import-environment

# Start the Hyprland session
# This will trigger the entire dependency chain:
# hyprland-session.target -> hyprland.service + hyprland-session-pre.target -> hyprland-env.service
exec systemctl --user start --wait hyprland-session.target
