#!/usr/bin/env bash

set -euo pipefail

updates=$(flatpak remote-ls --updates 2>/dev/null || true)

if [ -z "$updates" ]; then
    notify_all "Flatpak" "No updates available"
    exit 0
fi

update_count=$(echo "$updates" | wc -l)
notify_all "Flatpak" "Updating $update_count packages..."

flatpak update --noninteractive --assumeyes
notify_all "Flatpak" "Updates completed successfully"
