#!/usr/bin/env bash

set -euo pipefail

UPDATES=$(flatpak remote-ls --updates 2>/dev/null || true)

if [[ -z "${UPDATES}" ]]; then
    exit 0
fi

UPDATES_COUNT=$(echo "$updates" | wc -l)
notify_all "Flatpak" "Updating ${UPDATES_COUNT} packages..."

flatpak update --noninteractive --assumeyes
TODAY_UPDATES=$(flatpak history | grep "$(date +"%b %d")" | grep "deploy update" | awk -F ' ' '{print $6}')
notify_all "Flatpak" "Flatpaks updated : ${TODAY_UPDATES}"
