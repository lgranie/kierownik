binds {
    // #"Keybind Cheatsheet"
    Mod+Slash hotkey-overlay-title="Keybind Cheatsheet" { spawn-sh "qs -c noctalia-shell ipc call plugin:keybind-cheatsheet toggle"; }

    // #"Applications"
    Mod+Return hotkey-overlay-title="Open a Terminal: foot client" { spawn "footclient"; }
    Mod+Shift+Return hotkey-overlay-title="Open a Terminal: foot" { spawn "foot"; }
    Mod+Space hotkey-overlay-title="Run an Application: Menu" { spawn-sh "qs -c noctalia-shell ipc call launcher toggle"; }
    Mod+B hotkey-overlay-title="Open Bookmark" { spawn-sh "qs -c noctalia-shell ipc call plugin:bookmarks toggle"; }
    Mod+Alt+L hotkey-overlay-title="Lock the Screen: swaylock" { spawn "swaylock"; }

    // Unified clipboard (Super+C/V/X works everywhere)
    Mod+C hotkey-overlay-title="Copy" { spawn-sh "wl-copy"; }
    Mod+X hotkey-overlay-title="Cut" { spawn-sh "wl-copy"; }
    Mod+V hotkey-overlay-title="Paste" { spawn-sh "wl-paste"; }
    Mod+Ctrl+V hotkey-overlay-title="Clipboard History" { spawn-sh "cliphist decode | wl-paste"; }

    // #"Window Management"
    Mod+W repeat=false hotkey-overlay-title="Close window" { close-window; }
    Mod+F hotkey-overlay-title="Maximize column" { maximize-column; }
    Mod+Alt+F hotkey-overlay-title="Full screen" { fullscreen-window; }
    Mod+T hotkey-overlay-title="Toggle window floating/tiling" { toggle-window-floating; }
    Mod+Ctrl+F hotkey-overlay-title="Expand column to available width" { expand-column-to-available-width; }
    Mod+Shift+V hotkey-overlay-title="Toggle focus between floating and tiling" { switch-focus-between-floating-and-tiling; }

    // #"Workspace Navigation"
    Mod+Left hotkey-overlay-title="Focus column left" { focus-column-left; }
    Mod+Right hotkey-overlay-title="Focus column right" { focus-column-right; }
    Mod+Up hotkey-overlay-title="Focus workspace up" { focus-workspace-up; }
    Mod+Down hotkey-overlay-title="Focus workspace down" { focus-workspace-down; }

    // #"Move to Monitor"
    Mod+Shift+Alt+Left hotkey-overlay-title="Move workspace to left monitor" { move-workspace-to-monitor-left; }
    Mod+Shift+Alt+Right hotkey-overlay-title="Move workspace to right monitor" { move-workspace-to-monitor-right; }
    Mod+Shift+Alt+Up hotkey-overlay-title="Move workspace to up monitor" { move-workspace-to-monitor-up; }
    Mod+Shift+Alt+Down hotkey-overlay-title="Move workspace to down monitor" { move-workspace-to-monitor-down; }

    // #"Swap Windows"
    Mod+Shift+Left hotkey-overlay-title="Consume or expel window left" { consume-or-expel-window-left; }
    Mod+Shift+Right hotkey-overlay-title="Consume or expel window right" { consume-or-expel-window-right; }

    // #"Resize"
    Mod+Minus hotkey-overlay-title="Set column width -10%" { set-column-width "-10%"; }
    Mod+Equal hotkey-overlay-title="Set column width +10%" { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Set window height -10%" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Set window height +10%" { set-window-height "+10%"; }

    // #"Column Management"
    Mod+BracketLeft hotkey-overlay-title="Consume or expel window left" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Consume or expel window right" { consume-or-expel-window-right; }
    Mod+Comma hotkey-overlay-title="Consume window into column" { consume-window-into-column; }
    Mod+Period hotkey-overlay-title="Expel window from column" { expel-window-from-column; }
    Mod+R hotkey-overlay-title="Switch preset column width" { switch-preset-column-width; }

    // #"Window Movement"
    Mod+Shift+R hotkey-overlay-title="Switch preset window height" { switch-preset-window-height; }
    Mod+Ctrl+R hotkey-overlay-title="Reset window height" { reset-window-height; }
    Mod+Ctrl+Left hotkey-overlay-title="Move column left" { move-column-left; }
    Mod+Ctrl+Right hotkey-overlay-title="Move column right" { move-column-right; }
    Mod+Ctrl+Up hotkey-overlay-title="Move window up" { move-window-up; }
    Mod+Ctrl+Down hotkey-overlay-title="Move window down" { move-window-down; }

    // #"Column Width Presets"
    Mod+1 hotkey-overlay-title="Set column width 33%" { set-column-width "33%"; }
    Mod+2 hotkey-overlay-title="Set column width 50%" { set-column-width "50%"; }
    Mod+3 hotkey-overlay-title="Set column width 66%" { set-column-width "66%"; }
    Mod+4 hotkey-overlay-title="Set column width 100%" { set-column-width "100%"; }

    // #"Focus First/Last"
    Mod+Home hotkey-overlay-title="Focus first window in column" { focus-column-first; }
    Mod+End hotkey-overlay-title="Focus last window in column" { focus-column-last; }
    Mod+Ctrl+Home hotkey-overlay-title="Move column to first" { move-column-to-first; }
    Mod+Ctrl+End hotkey-overlay-title="Move column to last" { move-column-to-last; }

    // #"System"
    Mod+Shift+E hotkey-overlay-title="Quit" { quit; }
    Mod+Shift+Slash hotkey-overlay-title="Show hotkey overlay" { show-hotkey-overlay; }
    Mod+O repeat=false hotkey-overlay-title="Toggle overview" { toggle-overview; }
}
