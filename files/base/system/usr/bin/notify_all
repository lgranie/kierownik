#!/usr/bin/env bash

set -euo pipefail

while IFS=$': \t' read -r session type name; do
  if [[ "$type" == "wayland" ]]; then
    systemd-run --machine="$name@.host" --user --no-ask-password notify-send "$1" "$2" 2>/dev/null || true
  fi
done < <(loginctl list-sessions --no-legend 2>/dev/null | awk '{print $1, $3, $2}' || true)
